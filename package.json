    "vite": "^7.2.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-static-copy": "^3.3.0",
    "vitest": "^4.1.0"
  },
  "exports": {
    "./index.css": {
      "import": "./dist/index.css",
      "require": "./dist/index.css"
